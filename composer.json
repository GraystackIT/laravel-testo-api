{
    "name": "graystackit/laravel-testo-api",
    "description": "Laravel package for the Testo Saveris Data API, built on Saloon 4",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "testo", "saveris", "temperature", "humidity", "logger", "saloon"],
    "homepage": "https://github.com/GraystackIT/laravel-testo-api",
    "authors": [
        {
            "name": "GraystackIT"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "GraystackIT\\TestoCloud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GraystackIT\\TestoCloud\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GraystackIT\\TestoCloud\\TestoCloudServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
